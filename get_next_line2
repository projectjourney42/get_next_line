	ft_strjoin(stock, buf);
	*/
	if (!stock)
	{
		free(stock);
		stock = ft_strdup("");
		return (NULL);
	}
}

int	find_nl(char *stock)
{
	if (!stock)
		return (0);
	while (stock)
	{
		if (*stock == '\n')
			return (1);
		stock++;
	}
	return (0);
}

char	*print_line(char *stock)
{
	while (!find_nl())
	{
		new_stock = add_to_stock();
		stock = new_stock;
		free(new_stock);
	}
	if (find_nl() || /*end_of_file*/)
		return (stock);
}

char	*get_next_line(int fd)
{
	static char	*stock;
	char		buf[BUFFER_SIZE + 1];
	char		*to_print;
	char		*new_stock;
	ssize_t		r;

	if (fd < 0 || BUFFER_SIZE <= 0)
		return (NULL);
	while (!find_nl(stock))
	{
		r = read(fd, buf, BUFFER_SIZE);
		if (r > 0)
		{
			new_stock = add_to_stock(stock, buf, r);
			stock = new_stock;
			free(new_stock);
		}
	}
	if (find_nl() || r == 0)
		to_print = print_line(stock, r);
	if (r < 0)
		return (NULL);
	return (to_print);
}
